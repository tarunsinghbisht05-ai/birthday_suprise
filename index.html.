<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday 🎉</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            text-align: center;
            background: linear-gradient(135deg, #ff9a9e, #fad0c4);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .container {
            padding: 20px;
        }

        h1 {
            font-size: 50px;
            animation: glow 2s infinite alternate;
        }

        @keyframes glow {
            from { text-shadow: 0 0 10px #fff; }
            to { text-shadow: 0 0 30px #ff0; }
        }

        img {
            width: 80%;
            max-width: 300px;
            border-radius: 20px;
            margin-top: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        p {
            font-size: 20px;
            margin-top: 20px;
        }

        button {
            padding: 12px 25px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            background-color: #ff4081;
            color: white;
            cursor: pointer;
            transition: transform 0.2s;
        }

        button:hover {
            background-color: #e91e63;
            transform: scale(1.05);
        }

        #videoBox {
            display: none;
            margin-top: 20px;
        }
        
        video {
            max-width: 100%;
            border-radius: 10px;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🎉 Happy Birthday! 🎂</h1>
    <img src="https://via.placeholder.com/300" alt="Birthday Image">
    <p>Wishing you happiness, love and lots of cake 🎁💖</p>

    <button onclick="playVideo()">Click for Surprise 🎊</button>

    <div id="VideoBox">
style="display:none;".
        <video id="birthdayVideo" width="300" controls>
            <source src="birthdayyyyy.mp4" type="video/mp4">
            Your browser does not support video.
        </video>
    </div>
</div>

<script>
function playVideo() {
    var box = document.getElementById("videoBox");
    var video = document.getElementById("birthdayyyyy.mp4");
    
    // Show the hidden div
    box.style.display = "block";
    
    // Automatically start playing the video
    video.play();
}
</script>

</body>
</html>
